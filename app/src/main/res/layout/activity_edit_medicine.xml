<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/surface_card"
        android:elevation="1dp"
        app:layout_constraintTop_toTopOf="parent"
        app:title="@string/edit_medicine"
        app:titleTextAppearance="@style/ToolbarTitle"
        app:titleTextColor="@color/brand_primary"/>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                style="@style/SectionHeader"
                android:layout_marginTop="0dp"
                android:text="@string/medicine_details"/>

            <FrameLayout
                android:id="@+id/image_picker_container"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_pill_circle"
                android:clickable="true"
                android:focusable="true">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/medicine_image_preview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/CircularImage"
                    android:contentDescription="@string/medicine_photo"/>

                <ImageView
                    android:id="@+id/image_picker_icon"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_camera_plus"
                    android:contentDescription="@string/add_photo"/>
            </FrameLayout>

            <TextView
                android:id="@+id/image_picker_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="@string/add_photo"
                android:textColor="@color/brand_primary"
                android:textStyle="bold"
                android:textSize="14sp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="14dp"/>

            <TextView style="@style/FormLabel" android:text="@string/medicine_name"/>

            <EditText
                android:id="@+id/medicine_name"
                style="@style/FormInput"
                android:hint="@string/medicine_name"
                android:inputType="text"/>

            <TextView
                android:id="@+id/medicine_name_error"
                style="@style/ErrorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"/>

            <TextView style="@style/FormLabel" android:text="@string/dosage"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/dosage"
                    style="@style/FormInput"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:hint="@string/dosage"
                    android:inputType="text"/>

                <Spinner
                    android:id="@+id/dosage_unit_spinner"
                    android:layout_width="80dp"
                    android:layout_height="52dp"
                    android:entries="@array/dosage_units"
                    android:background="@drawable/bg_input"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:layout_marginStart="8dp"
                    android:spinnerMode="dropdown"/>
            </LinearLayout>

            <TextView
                android:id="@+id/dosage_error"
                style="@style/ErrorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"/>

            <TextView style="@style/FormLabel" android:text="@string/medicine_type"/>

            <Spinner
                android:id="@+id/medicine_type"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:entries="@array/medicine_types"
                android:background="@drawable/bg_input"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:spinnerMode="dropdown"/>

            <TextView
                android:id="@+id/medicine_type_error"
                style="@style/ErrorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"/>

            <TextView style="@style/FormLabel" android:text="@string/total_stock"/>

            <EditText
                android:id="@+id/total_stock"
                style="@style/FormInput"
                android:hint="@string/total_stock"
                android:inputType="numberDecimal"/>

            <TextView
                android:id="@+id/total_stock_error"
                style="@style/ErrorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"/>

            <TextView style="@style/FormLabel" android:text="@string/daily_consumption"/>

            <EditText
                android:id="@+id/daily_consumption"
                style="@style/FormInput"
                android:hint="@string/daily_consumption"
                android:inputType="numberDecimal"/>

            <TextView
                android:id="@+id/daily_consumption_error"
                style="@style/ErrorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"/>

            <TextView
                style="@style/SectionHeader"
                android:text="@string/reminder_times"/>

            <LinearLayout
                android:id="@+id/time_pickers_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

            <TextView
                android:id="@+id/time_picker_error"
                style="@style/ErrorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"/>

            <TextView style="@style/FormLabel" android:text="@string/repeat"/>

            <com.example.medicinereminderapp.DayOfWeekPicker
                android:id="@+id/day_picker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/repeat_hint"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginTop="6dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_input">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/active_label"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/active_hint"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/active_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"/>
            </LinearLayout>

            <Button
                android:id="@+id/save_btn"
                style="@style/PrimaryButton"
                android:layout_width="match_parent"
                android:text="@string/save"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"/>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
